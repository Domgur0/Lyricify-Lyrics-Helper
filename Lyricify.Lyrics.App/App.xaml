<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="Lyricify.Lyrics.App.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Highlight colour for the active lyric line -->
            <Color x:Key="ActiveLineColor">#1DB954</Color>
            <!-- Default lyric line colour -->
            <Color x:Key="InactiveLineColor">#B3FFFFFF</Color>
            <!-- Background of the lyrics page -->
            <Color x:Key="PageBackground">#121212</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
