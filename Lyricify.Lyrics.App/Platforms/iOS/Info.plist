<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App display name -->
    <key>CFBundleDisplayName</key>
    <string>Lyricify</string>

    <!-- Bundle identifier – must match ApplicationId in csproj -->
    <key>CFBundleIdentifier</key>
    <string>com.lyricify.lyrics.app</string>

    <!-- Version info -->
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Minimum iOS version -->
    <key>MinimumOSVersion</key>
    <string>15.0</string>

    <!-- Explicit orientations to avoid iOS build-time warning -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Redirect URI: lyricify://callback
         MAUI WebAuthenticator intercepts this custom scheme after Spotify redirects.
         The scheme must also be listed in CFBundleURLTypes below. -->

    <!-- Register the custom URL scheme so iOS routes lyricify://callback back to the app -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.lyricify.lyrics.app.oauth</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>lyricify</string>
            </array>
        </dict>
    </array>

    <!-- Allow outbound HTTPS (Spotify API, LRCLIB) -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSExceptionDomains</key>
        <dict>
            <key>api.spotify.com</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
            <key>lrclib.net</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <false/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>

    <!-- Network usage description (shown in system permission prompt) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Lyricify connects to Spotify and lyrics providers to fetch lyrics for your currently playing track.</string>
</dict>
</plist>
