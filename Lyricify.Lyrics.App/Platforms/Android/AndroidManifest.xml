<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.lyricify.lyrics.app">

    <!-- Internet access for Spotify API and lyrics providers -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Draw over other apps (floating window) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Keep the overlay service alive in the foreground -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required on Android 14+ when foregroundServiceType="specialUse" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Post notifications (required on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/appicon"
        android:roundIcon="@mipmap/appicon_round"
        android:supportsRtl="true"
        android:label="Lyricify">

        <!-- Spotify OAuth2 redirect URI handler is implemented in
             Platforms/Android/SpotifyWebAuthenticatorCallbackActivity.cs. -->

        <!-- Floating lyrics foreground service -->
        <service
            android:name=".LyricsOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- SuperLyric standalone foreground service (no overlay window) -->
        <service
            android:name=".SuperLyricService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Flyme status-bar lyrics standalone foreground service (no overlay window) -->
        <service
            android:name=".FlymeStatusBarService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Notification-listener stub used by compatibility mode to call
             MediaSessionManager.GetActiveSessions(). The user must grant
             notification-listener access via system settings. -->
        <service
            android:name=".MediaNotificationListenerService"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
    </application>
</manifest>
