<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Lyricify.Lyrics.App.Views.LyricsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Lyricify.Lyrics.App.ViewModels"
    xmlns:models="clr-namespace:Lyricify.Lyrics.Models;assembly=Lyricify.Lyrics.Helper"
    x:DataType="vm:LyricsViewModel"
    Title="Now Playing"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- ── Now-playing header ──────────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="64,*"
            Padding="12,8"
            BackgroundColor="#1A1A1A">

            <!-- Album art -->
            <ImageButton
                Grid.Column="0"
                Source="{Binding AlbumArtSource}"
                HeightRequest="56"
                WidthRequest="56"
                Aspect="AspectFill"
                CornerRadius="6"
                BackgroundColor="Transparent"
                Padding="0"
                Pressed="OnAlbumArtPressed"
                Released="OnAlbumArtReleased" />

            <!-- Title / artist -->
            <VerticalStackLayout
                Grid.Column="1"
                Spacing="4"
                VerticalOptions="Center"
                Padding="12,0,0,0">
                <Label
                    Text="{Binding TrackTitle}"
                    TextColor="White"
                    FontSize="14"
                    FontAttributes="Bold"
                    LineBreakMode="TailTruncation" />
                <Label
                    Text="{Binding ArtistName}"
                    TextColor="{StaticResource InactiveLineColor}"
                    FontSize="12"
                    LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1">
            <!-- ── Lyrics list ────────────────────────────────────────────── -->
            <CollectionView
                x:Name="LyricsCollection"
                ItemsSource="{Binding LyricLines}"
                BackgroundColor="{StaticResource PageBackground}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ILineInfo">
                        <Label
                            x:Name="LineLabel"
                            Text="{Binding Text}"
                            TextColor="{StaticResource InactiveLineColor}"
                            FontSize="17"
                            Padding="20,8"
                            HorizontalTextAlignment="Center"
                            HorizontalOptions="Fill" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Grid IsVisible="{Binding IsLoadingLyrics}">
                <ActivityIndicator
                    IsRunning="True"
                    Color="{StaticResource ActiveLineColor}"
                    VerticalOptions="Center"
                    HorizontalOptions="Center" />
            </Grid>

            <Label
                x:Name="StatusMessageLabel"
                Text="{Binding LyricsStatusMessage}"
                IsVisible="{Binding HasStatusMessage}"
                TextColor="{StaticResource InactiveLineColor}"
                HorizontalTextAlignment="Center"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Padding="20" />

            <!-- ── Android-only: floating window toggle ───────────────────── -->
            <Button
                x:Name="OverlayToggleButton"
                Text="🪟  Show floating lyrics"
                BackgroundColor="#1DB954"
                TextColor="Black"
                CornerRadius="20"
                HeightRequest="44"
                Margin="20,0,20,24"
                VerticalOptions="End"
                Clicked="OnToggleOverlayClicked"
                IsVisible="{OnPlatform Default=False, Android=True}" />
        </Grid>
    </Grid>
</ContentPage>
