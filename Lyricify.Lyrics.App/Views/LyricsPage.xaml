<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Lyricify.Lyrics.App.Views.LyricsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Lyricify.Lyrics.App.ViewModels"
    xmlns:models="clr-namespace:Lyricify.Lyrics.Models;assembly=Lyricify.Lyrics.Helper"
    x:DataType="vm:LyricsViewModel"
    Title="Now Playing"
    BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="0">

        <!-- ── Now-playing header ──────────────────────────────────────────── -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="80,*"
            Padding="16,12"
            BackgroundColor="#1A1A1A">

            <!-- Album art -->
            <Image
                Grid.Column="0"
                Source="{Binding AlbumArtUrl}"
                HeightRequest="64"
                WidthRequest="64"
                Aspect="AspectFill">
                <Image.Clip>
                    <RoundRectangleGeometry CornerRadius="6" Rect="0,0,64,64" />
                </Image.Clip>
            </Image>

            <!-- Title / artist -->
            <VerticalStackLayout
                Grid.Column="1"
                Spacing="4"
                VerticalOptions="Center"
                Padding="12,0,0,0">
                <Label
                    Text="{Binding TrackTitle}"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    LineBreakMode="TailTruncation" />
                <Label
                    Text="{Binding ArtistName}"
                    TextColor="{StaticResource InactiveLineColor}"
                    FontSize="13"
                    LineBreakMode="TailTruncation" />
            </VerticalStackLayout>
        </Grid>

        <!-- ── Loading / no-lyrics state ─────────────────────────────────── -->
        <Grid Grid.Row="1" IsVisible="{Binding IsLoadingLyrics}" Padding="16,8">
            <ActivityIndicator IsRunning="True" Color="{StaticResource ActiveLineColor}" />
        </Grid>

        <Label
            Grid.Row="1"
            Text="No lyrics available for this track."
            TextColor="{StaticResource InactiveLineColor}"
            HorizontalOptions="Center"
            Padding="16,8"
            IsVisible="{Binding ShowNoLyricsHint}" />

        <!-- ── Lyrics list ────────────────────────────────────────────────── -->
        <CollectionView
            x:Name="LyricsCollection"
            Grid.Row="2"
            ItemsSource="{Binding LyricLines}"
            BackgroundColor="{StaticResource PageBackground}"
            SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ILineInfo">
                    <!-- Each row is a lyric line.  The active line uses a larger, coloured label. -->
                    <Label
                        x:Name="LineLabel"
                        Text="{Binding Text}"
                        TextColor="{StaticResource InactiveLineColor}"
                        FontSize="17"
                        Padding="20,8"
                        HorizontalTextAlignment="Center"
                        HorizontalOptions="Fill" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ── Android-only: floating window toggle ───────────────────────── -->
        <Button
            Grid.Row="2"
            Text="🪟  Show floating lyrics"
            BackgroundColor="#1DB954"
            TextColor="Black"
            CornerRadius="20"
            HeightRequest="44"
            Margin="20,0,20,24"
            VerticalOptions="End"
            Clicked="OnToggleOverlayClicked"
            IsVisible="{OnPlatform Default=False, Android=True}" />
    </Grid>
</ContentPage>
