<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Lyricify.Lyrics.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Sign in"
    BackgroundColor="{StaticResource PageBackground}">

    <VerticalStackLayout
        Padding="40"
        Spacing="24"
        VerticalOptions="Center">

        <!-- Logo / branding -->
        <Label
            FontSize="36"
            HorizontalOptions="Center"
            Text="🎵 Lyricify"
            TextColor="{StaticResource ActiveLineColor}" />

        <Label
            FontSize="16"
            HorizontalOptions="Center"
            Text="Sign in with Spotify to see lyrics for your currently playing track."
            TextColor="{StaticResource InactiveLineColor}"
            HorizontalTextAlignment="Center" />

        <!-- Optional: sp_dc cookie for Spotify's internal lyrics endpoint -->
        <Frame
            BackgroundColor="#1A1A1A"
            BorderColor="#333333"
            CornerRadius="8"
            Padding="16">
            <VerticalStackLayout Spacing="8">
                <Label
                    Text="Spotify sp_dc cookie (optional)"
                    TextColor="{StaticResource InactiveLineColor}"
                    FontSize="13" />
                <Entry
                    x:Name="SpDcEntry"
                    Placeholder="Paste your sp_dc cookie here for better lyrics"
                    PlaceholderColor="#666666"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    IsPassword="true" />
                <Label
                    Text="Used only to fetch Spotify's own lyrics.  Not required — LRCLIB will be used as fallback."
                    TextColor="#888888"
                    FontSize="11"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Frame>

        <!-- Login button -->
        <Button
            x:Name="LoginButton"
            Text="Connect Spotify"
            BackgroundColor="{StaticResource ActiveLineColor}"
            TextColor="Black"
            FontAttributes="Bold"
            CornerRadius="24"
            HeightRequest="52"
            Clicked="OnLoginClicked" />

        <!-- Status label -->
        <Label
            x:Name="StatusLabel"
            Text=""
            TextColor="#FF5555"
            HorizontalOptions="Center"
            IsVisible="False" />

        <!-- Activity indicator -->
        <ActivityIndicator
            x:Name="Spinner"
            IsRunning="False"
            IsVisible="False"
            Color="{StaticResource ActiveLineColor}" />
    </VerticalStackLayout>
</ContentPage>
