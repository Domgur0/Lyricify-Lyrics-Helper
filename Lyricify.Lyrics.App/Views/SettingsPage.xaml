<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Lyricify.Lyrics.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Settings"
    BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- ── Spotify credentials ────────────────────────────────────── -->
            <Label Text="Spotify" TextColor="White" FontSize="18" FontAttributes="Bold" />

            <!-- Login status (only shown when signed in) -->
            <Border
                x:Name="LoginStatusFrame"
                Background="#0D1B12"
                Stroke="#1DB954"
                Padding="12"
                IsVisible="False">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label
                        x:Name="LoginStatusLabel"
                        TextColor="#1DB954"
                        FontSize="13"
                        FontAttributes="Bold" />
                    <Label
                        x:Name="LoginExpiryLabel"
                        TextColor="#888888"
                        FontSize="11" />
                </VerticalStackLayout>
            </Border>

            <Border Background="#1A1A1A" Stroke="#333333" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <!-- Client ID -->
                    <Label Text="Client ID" TextColor="{StaticResource InactiveLineColor}" FontSize="13" />
                    <Entry
                        x:Name="ClientIdEntry"
                        Placeholder="Enter your Spotify Client ID"
                        PlaceholderColor="#666666"
                        TextColor="White"
                        BackgroundColor="Transparent" />

                    <!-- Client Secret -->
                    <Label Text="Client Secret" TextColor="{StaticResource InactiveLineColor}" FontSize="13" />
                    <Entry
                        x:Name="ClientSecretEntry"
                        Placeholder="Enter your Spotify Client Secret"
                        PlaceholderColor="#666666"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        IsPassword="true" />

                    <Label
                        Text="Find these values in your app at developer.spotify.com/dashboard.&#x0a;Redirect URI must be set to lyricify://callback."
                        TextColor="#888888"
                        FontSize="11"
                        HorizontalTextAlignment="Center" />

                    <!-- sp_dc cookie -->
                    <Label Text="sp_dc cookie (optional)" TextColor="{StaticResource InactiveLineColor}" FontSize="13" />
                    <Entry
                        x:Name="SpDcEntry"
                        Placeholder="Paste your sp_dc cookie"
                        PlaceholderColor="#666666"
                        TextColor="White"
                        BackgroundColor="Transparent"
                        IsPassword="true" />
                    <Label
                        Text="Used to fetch Spotify's own lyrics. Not required — LRCLIB is used as fallback."
                        TextColor="#888888"
                        FontSize="11"
                        HorizontalTextAlignment="Center" />

                    <Button
                        Text="Sign in to Spotify"
                        BackgroundColor="{StaticResource ActiveLineColor}"
                        TextColor="Black"
                        CornerRadius="8"
                        HeightRequest="40"
                        Clicked="OnSignInClicked" />

                    <Button
                        Text="Save Credentials"
                        BackgroundColor="{StaticResource ActiveLineColor}"
                        TextColor="Black"
                        CornerRadius="8"
                        HeightRequest="40"
                        Clicked="OnSaveCredentialsClicked" />

                    <Button
                        Text="Sign out of Spotify"
                        BackgroundColor="#333333"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="40"
                        Clicked="OnSignOutClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- ── Display ───────────────────────────────────────────────── -->
            <Label Text="Display" TextColor="White" FontSize="18" FontAttributes="Bold" />

            <Border Background="#1A1A1A" Stroke="#333333" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Font size" TextColor="{StaticResource InactiveLineColor}" FontSize="13" />
                    <Slider
                        x:Name="FontSizeSlider"
                        Minimum="12"
                        Maximum="32"
                        Value="17"
                        ThumbColor="{StaticResource ActiveLineColor}"
                        MinimumTrackColor="{StaticResource ActiveLineColor}"
                        ValueChanged="OnFontSizeChanged" />
                    <Label
                        x:Name="FontSizeLabel"
                        Text="17"
                        TextColor="{StaticResource InactiveLineColor}"
                        HorizontalOptions="End"
                        FontSize="13" />

                    <!-- Android-only: overlay opacity -->
                    <Label
                        Text="Overlay opacity"
                        TextColor="{StaticResource InactiveLineColor}"
                        FontSize="13"
                        IsVisible="{OnPlatform Default=False, Android=True}" />
                    <Slider
                        x:Name="OpacitySlider"
                        Minimum="0.3"
                        Maximum="1.0"
                        Value="0.9"
                        ThumbColor="{StaticResource ActiveLineColor}"
                        MinimumTrackColor="{StaticResource ActiveLineColor}"
                        ValueChanged="OnOverlayOpacityChanged"
                        IsVisible="{OnPlatform Default=False, Android=True}" />

                    <Grid
                        ColumnDefinitions="*,Auto"
                        IsVisible="{OnPlatform Default=False, Android=True}">
                        <Label
                            Text="Enable floating desktop lyrics"
                            TextColor="{StaticResource InactiveLineColor}"
                            FontSize="13"
                            VerticalOptions="Center" />
                        <Switch
                            x:Name="OverlayEnabledSwitch"
                            Grid.Column="1"
                            Toggled="OnOverlayEnabledToggled"
                            OnColor="{StaticResource ActiveLineColor}" />
                    </Grid>

                    <Grid
                        ColumnDefinitions="*,Auto"
                        IsVisible="{OnPlatform Default=False, Android=True}">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                            <Label
                                Text="Enable Flyme status bar lyrics"
                                TextColor="{StaticResource InactiveLineColor}"
                                FontSize="13" />
                            <Label
                                Text="Show lyrics in Meizu Flyme status bar (Flyme devices only)"
                                TextColor="#888888"
                                FontSize="11" />
                        </VerticalStackLayout>
                        <Switch
                            x:Name="FlymeStatusBarSwitch"
                            Grid.Column="1"
                            Toggled="OnFlymeStatusBarToggled"
                            OnColor="{StaticResource ActiveLineColor}" />
                    </Grid>

                    <Button
                        Text="Unlock floating lyrics"
                        BackgroundColor="#333333"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="40"
                        Clicked="OnUnlockOverlayClicked"
                        IsVisible="{OnPlatform Default=False, Android=True}" />

                    <!-- Android-only: floating lyrics current-line color -->
                    <Label
                        Text="Floating lyrics color"
                        TextColor="{StaticResource InactiveLineColor}"
                        FontSize="13"
                        IsVisible="{OnPlatform Default=False, Android=True}" />
                    <HorizontalStackLayout
                        Spacing="10"
                        IsVisible="{OnPlatform Default=False, Android=True}">
                        <Border
                            x:Name="ColorSwatchRed"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#E05252"
                            Stroke="Transparent"
                            StrokeThickness="3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOverlayColorSelected" CommandParameter="#E05252" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border
                            x:Name="ColorSwatchBlue"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#39B4E8"
                            Stroke="Transparent"
                            StrokeThickness="3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOverlayColorSelected" CommandParameter="#39B4E8" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border
                            x:Name="ColorSwatchGreen"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#52C57A"
                            Stroke="Transparent"
                            StrokeThickness="3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOverlayColorSelected" CommandParameter="#52C57A" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border
                            x:Name="ColorSwatchGold"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#C9A84C"
                            Stroke="Transparent"
                            StrokeThickness="3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOverlayColorSelected" CommandParameter="#C9A84C" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border
                            x:Name="ColorSwatchPurple"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#7B5CC7"
                            Stroke="Transparent"
                            StrokeThickness="3">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOverlayColorSelected" CommandParameter="#7B5CC7" />
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- ── About ─────────────────────────────────────────────────── -->
            <Label Text="About" TextColor="White" FontSize="18" FontAttributes="Bold" />
            <Border Background="#1A1A1A" Stroke="#333333" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="4">
                    <Label Text="Lyricify 1.0.0" TextColor="White" FontSize="14" />
                    <Label Text="Powered by Lyricify Lyrics Helper" TextColor="{StaticResource InactiveLineColor}" FontSize="12" />
                    <Label Text="Lyrics provided by Spotify and LRCLIB" TextColor="{StaticResource InactiveLineColor}" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- ── Diagnostics ───────────────────────────────────────────── -->
            <Label Text="Diagnostics" TextColor="White" FontSize="18" FontAttributes="Bold" />
            <Border Background="#1A1A1A" Stroke="#333333" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="Exports warnings and errors captured since the last launch."
                        TextColor="{StaticResource InactiveLineColor}"
                        FontSize="12" />
                    <Button
                        Text="Export Log"
                        BackgroundColor="#333333"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="40"
                        Clicked="OnExportLogClicked" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
